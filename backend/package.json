{
  "name": "ai-readiness-voice-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Lambda backend for AI Readiness Voice Interview",
  "scripts": {
    "build": "tsc",
    "package": "npm run build && cd dist && zip -r ../lambda-package.zip .",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-secrets-manager": "^3.500.0",
    "@aws-sdk/client-ses": "^3.1000.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
